<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.edulink.gui.controllers.event.QRScannerController"
      spacing="20" alignment="CENTER"
      style="-fx-padding: 30; -fx-background-color: #1a1a2e;">

    <Label text="📷 Scanner QR Code"
           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <!-- Flux webcam -->
    <ImageView fx:id="webcamView"
               fitWidth="640" fitHeight="480"
               preserveRatio="true"
               style="-fx-border-color: #3498DB; -fx-border-width: 3; -fx-border-radius: 10;"/>

    <!-- Status -->
    <Label fx:id="statusLabel" text="Prêt à scanner"
           style="-fx-font-size: 14; -fx-text-fill: #BDC3C7;"/>

    <!-- Boutons -->
    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="startBtn" text="▶ Démarrer"
                onAction="#handleStartScan"
                style="-fx-background-color: #27AE60; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-padding: 10 20; -fx-border-radius: 5;"/>
        <Button fx:id="stopBtn" text="⏹ Arrêter"
                onAction="#handleStopScan"
                style="-fx-background-color: #E74C3C; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-padding: 10 20; -fx-border-radius: 5;"/>
        <Button fx:id="importBtn" text="📁 Importer Image"
                onAction="#handleImportImage"
                style="-fx-background-color: #3498DB; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-padding: 10 20; -fx-border-radius: 5;"/>
    </HBox>

    <!-- Résultat -->
    <VBox fx:id="resultBox" spacing="10" alignment="CENTER"
          style="-fx-background-color: #16213e; -fx-padding: 20;
                 -fx-border-radius: 10; -fx-background-radius: 10;">
        <Label text="Résultat du scan"
               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label fx:id="resultLabel" text=""
               style="-fx-font-size: 13; -fx-text-fill: #BDC3C7;"
               wrapText="true"/>
    </VBox>

</VBox>