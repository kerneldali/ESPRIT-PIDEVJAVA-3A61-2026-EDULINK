<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edulink.gui.controllers.courses.MatiereListController">
    <!-- Main Content -->
    <VBox spacing="20" styleClass="main-container">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="Browse Categories" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Propose Category" onAction="#handleSuggestMatiere" style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
        
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #1a1a2e; -fx-padding: 12; -fx-background-radius: 8;">
            <TextField fx:id="searchField" promptText="🔍 Search categories..." HBox.hgrow="ALWAYS" style="-fx-background-color: #2a2a3e; -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>
            <ComboBox fx:id="filterCombo" promptText="Sort By" style="-fx-background-color: #2a2a3e; -fx-text-fill: white;" />
        </HBox>
        
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #7c3aed11; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #7c3aed44; -fx-border-radius: 8;">
            <Label text="✨ Discover:" style="-fx-text-fill: #b18cff; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <TextField fx:id="recommendField" promptText="What do you want to learn? (AI, Java, Design...)" HBox.hgrow="ALWAYS" style="-fx-background-color: #2a2a3e; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <Button text="Recommend" onAction="#handleRecommend" style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"/>
        </HBox>
        
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <FlowPane fx:id="matiereContainer" hgap="20" vgap="20" />
        </ScrollPane>
    </VBox>
    
    <!-- Suggestion Overlay Form -->
    <VBox fx:id="formOverlay" alignment="CENTER" visible="false" style="-fx-background-color: #000000bb;">
        <VBox spacing="15" maxWidth="450" style="-fx-background-color: #16162a; -fx-padding: 30; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #7c3aed44; -fx-border-width: 1;">
            <Label text="Propose New Category" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 20px;"/>
            <Label text="Your suggestion will be sent to admin for review." style="-fx-text-fill: #a0a0ab; -fx-font-size: 12px;"/>
            
            <VBox spacing="5">
                <Label text="Category Name *" style="-fx-text-fill: #a0a0ab; -fx-font-size: 12px;"/>
                <TextField fx:id="suggestNameField" promptText="e.g. Artificial Intelligence" style="-fx-background-color: #2a2a3e; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-prompt-text-fill: #555;"/>
                <Label fx:id="suggestNameError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Description / Reason" style="-fx-text-fill: #a0a0ab; -fx-font-size: 12px;"/>
                <TextArea fx:id="suggestDescField" promptText="Why should this category exist?" prefRowCount="3" style="-fx-control-inner-background: #2a2a3e; -fx-text-fill: white; -fx-prompt-text-fill: #555;"/>
            </VBox>
            
            <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                <Button text="Cancel" onAction="#handleCloseSuggest" style="-fx-background-color: transparent; -fx-text-fill: #a0a0ab; -fx-cursor: hand;"/>
                <Button fx:id="suggestSaveBtn" text="Submit Proposal" onAction="#handleSubmitSuggest" style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
