<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edulink.gui.controllers.courses.AnalyzeActivityController" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
    
    <VBox spacing="35" style="-fx-padding: 40; -fx-background-color: #0f0f1a; -fx-font-family: 'Segoe UI', Tahoma, Verdana, sans-serif;">
        <!-- Header & Stats Area -->
        <VBox spacing="25">
            <VBox spacing="8">
                <Label text="Student Activity Analytics" style="-fx-font-size: 38px; -fx-font-weight: 900; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 4);"/>
                <Label text="Track student engagement, courses taken, and manual/auto remind inactive users." style="-fx-font-size: 18px; -fx-text-fill: #a0a0ab;"/>
            </VBox>
        </VBox>

        <!-- Search & Sort Bar -->
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #1a1a2e; -fx-padding: 20 30; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 20, 0, 0, 5);">
            <Label text="🔍" style="-fx-font-size: 20px;"/>
            <TextField fx:id="searchField" promptText="Search by name, email..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-text-fill: white;"/>
            <Separator orientation="VERTICAL" style="-fx-padding: 0 10;"/>
            <Label text="Filter Status:" style="-fx-font-weight: 800; -fx-text-fill: #a0a0ab;"/>
            <ComboBox fx:id="statusCombo" prefWidth="200" style="-fx-background-color: #2a2a3e; -fx-background-radius: 10; -fx-padding: 5 10;"/>
        </HBox>

        <!-- Main Workspace -->
        <VBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1a2e; -fx-padding: 30; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 30, 0, 0, 10); -fx-border-color: #ffffff11; -fx-border-radius: 20;">
            <Label text="Student Engagement Ledger" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: white;"/>
            <TableView fx:id="activityTable" prefHeight="650" style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #ffffff11; -fx-font-size: 15px; -fx-selection-bar: #dbeafe;">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="nameCol" text="Full Name" prefWidth="180"/>
                    <TableColumn fx:id="emailCol" text="Email Address" prefWidth="220"/>
                    <TableColumn fx:id="scoreCol" text="Score" prefWidth="80"/>
                    <TableColumn fx:id="xpCol" text="Total XP" prefWidth="80"/>
                    <TableColumn fx:id="coursesCol" text="Courses" prefWidth="80"/>
                    <TableColumn fx:id="lastActivityCol" text="Last Activity" prefWidth="150"/>
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="actionCol" text="Action" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
