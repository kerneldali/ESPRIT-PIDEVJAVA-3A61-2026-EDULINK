<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edulink.gui.controllers.courses.ManageCoursesController">
    <!-- Main Content -->
    <VBox spacing="20" styleClass="main-container">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Button text="← Back to Categories" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: #a0a0ab; -fx-cursor: hand;" />
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label fx:id="pageTitle" text="Courses in Category" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22px;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="+ Add Course" onAction="#handleNewCourse" style="-fx-background-color: #00d289; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
        
        <!-- Filter Bar -->
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #1a1a2e; -fx-padding: 12; -fx-background-radius: 8;">
            <TextField fx:id="searchField" promptText="🔍 Search courses in this category..." prefWidth="300" HBox.hgrow="ALWAYS" style="-fx-background-color: #2a2a3e; -fx-text-fill: white; -fx-prompt-text-fill: #666;"/>
            <ComboBox fx:id="levelComboFilter" promptText="All Levels" style="-fx-background-color: #2a2a3e;"/>
            <ComboBox fx:id="sortCombo" promptText="Newest First" style="-fx-background-color: #2a2a3e;"/>
        </HBox>
        
        <!-- Table-style List -->
        <VBox style="-fx-background-color: #1a1a2e; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ffffff11; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
            <Label text="Courses in this Category" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 0 0 10 0;"/>
            
            <!-- Column Header -->
            <HBox spacing="10" style="-fx-padding: 8 15; -fx-border-color: transparent transparent #ffffff11 transparent;">
                <Label text="Course Title" prefWidth="200" style="-fx-text-fill: #a0a0ab; -fx-font-weight: bold;"/>
                <Label text="Level" prefWidth="120" style="-fx-text-fill: #a0a0ab; -fx-font-weight: bold;"/>
                <Label text="XP" prefWidth="80" style="-fx-text-fill: #a0a0ab; -fx-font-weight: bold;"/>
                <Label text="Resources" prefWidth="80" style="-fx-text-fill: #a0a0ab; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Actions" style="-fx-text-fill: #a0a0ab; -fx-font-weight: bold;"/>
            </HBox>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                <VBox fx:id="cardContainer" spacing="5" />
            </ScrollPane>
        </VBox>
    </VBox>
    
    <!-- Overlay Form -->
    <VBox fx:id="formOverlay" alignment="CENTER" visible="false" style="-fx-background-color: #000000bb;">
        <VBox spacing="15" maxWidth="450" style="-fx-background-color: #16162a; -fx-padding: 30; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #7c3aed44; -fx-border-width: 1;">
            <Label fx:id="formTitle" text="New Course" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 20px;"/>
            
            <VBox spacing="5">
                <Label text="Course Title *" style="-fx-text-fill: #a0a0ab; -fx-font-size: 12px;"/>
                <TextField fx:id="titleField" promptText="Enter course title" style="-fx-background-color: #2a2a3e; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-prompt-text-fill: #555;"/>
                <Label fx:id="titleError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Description *" style="-fx-text-fill: #a0a0ab; -fx-font-size: 12px;"/>
                <TextArea fx:id="descField" promptText="Describe the course content..." prefRowCount="3" style="-fx-control-inner-background: #2a2a3e; -fx-text-fill: white; -fx-background-radius: 6; -fx-prompt-text-fill: #555;"/>
                <Label fx:id="descError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
            </VBox>
            
            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Level" style="-fx-text-fill: #a0a0ab; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="levelCombo" maxWidth="Infinity" style="-fx-background-color: #2a2a3e;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="XP Reward *" style="-fx-text-fill: #a0a0ab; -fx-font-size: 12px;"/>
                    <TextField fx:id="xpField" promptText="e.g. 50" style="-fx-background-color: #2a2a3e; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-prompt-text-fill: #555;"/>
                    <Label fx:id="xpError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>
            
            <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                <Button text="Cancel" onAction="#handleCloseForm" style="-fx-background-color: transparent; -fx-text-fill: #a0a0ab; -fx-cursor: hand;"/>
                <Button fx:id="saveBtn" text="Save Course" onAction="#handleSaveCourse" style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
