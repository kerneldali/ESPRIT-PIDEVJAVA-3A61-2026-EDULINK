<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edulink.gui.controllers.courses.ManageSuggestionsController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    
    <Label text="Review Center Hub" styleClass="page-title" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;"/>
    <Label text="Approve or reject student submissions." style="-fx-text-fill: #a0a0ab;"/>
    
    <!-- Filter Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 10;">
        <ComboBox fx:id="typeFilter" promptText="All Types" />
        <ComboBox fx:id="statusFilter" promptText="All Status" />
        <Button text="Apply Actions" styleClass="primary-button" style="-fx-background-color: #7c3aed; -fx-text-fill: white;"/>
    </HBox>
    
    <!-- Items container -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="hidden-scroll-pane" style="-fx-background-color: transparent;">
        <VBox fx:id="proposalsContainer" spacing="15" />
    </ScrollPane>
</VBox>
