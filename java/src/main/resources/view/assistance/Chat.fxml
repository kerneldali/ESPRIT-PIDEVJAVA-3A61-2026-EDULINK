<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.edulink.gui.controllers.assistance.ChatController"
      spacing="0" prefHeight="700" VBox.vgrow="ALWAYS"
      style="-fx-background-color:#0f172a;">

    <!-- Header -->
    <HBox style="-fx-background-color:#1e293b;-fx-padding:14 20;" spacing="16" alignment="CENTER_LEFT">
        <Label fx:id="sessionTitleLabel" text="Session Chat"
               style="-fx-text-fill:white;-fx-font-size:16;-fx-font-weight:bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="jitsiLinkLabel" text="📹 Open Video"
               style="-fx-text-fill:#a5b4fc;-fx-cursor:hand;-fx-font-size:13;"/>
        <Button fx:id="closeSessionBtn" text="✓ End Session" onAction="#handleCloseSession"
                style="-fx-background-color:#dc2626;-fx-text-fill:white;-fx-background-radius:8;-fx-padding:6 16;"/>
    </HBox>

    <!-- Session Info Bar -->
    <HBox style="-fx-background-color:#0f172a;-fx-padding:8 20;-fx-border-color:#1e293b;-fx-border-width:0 0 1 0;">
        <Label fx:id="sessionInfoLabel" text="Loading session info..."
               style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
    </HBox>

    <!-- Messages area -->
    <ScrollPane fx:id="messagesScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;">
        <VBox fx:id="messagesContainer" spacing="8">
            <padding><Insets top="16" bottom="16" left="12" right="12"/></padding>
        </VBox>
    </ScrollPane>

    <!-- AI Suggestion Chips -->
    <VBox style="-fx-background-color:#111827;-fx-padding:8 16 6 16;">
        <Label text="💡 Quick Replies" style="-fx-text-fill:#475569;-fx-font-size:11;"/>
        <HBox fx:id="suggestionsBar" spacing="8" style="-fx-padding:6 0 2 0;"/>
    </VBox>

    <!-- Input area -->
    <HBox style="-fx-background-color:#1e293b;-fx-padding:12 16;" spacing="10" alignment="CENTER">
        <TextField fx:id="messageInput" promptText="Write a message..."
                   onAction="#handleSend" HBox.hgrow="ALWAYS"
                   style="-fx-background-color:#0f172a;-fx-text-fill:white;-fx-prompt-text-fill:#475569;
                          -fx-border-color:#334155;-fx-border-radius:20;-fx-background-radius:20;-fx-padding:10 16;"/>
        <Button fx:id="sendBtn" text="➤ Send" onAction="#handleSend"
                style="-fx-background-color:#6366f1;-fx-text-fill:white;-fx-background-radius:20;-fx-padding:10 20;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>

    <!-- Status bar -->
    <Label fx:id="statusLabel" text=""
           style="-fx-background-color:#0f172a;-fx-text-fill:#64748b;-fx-font-size:11;-fx-padding:4 16 8 16;"/>
</VBox>
