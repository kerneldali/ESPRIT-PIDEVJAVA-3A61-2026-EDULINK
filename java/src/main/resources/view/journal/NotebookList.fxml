<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.edulink.gui.controllers.journal.NotebookController" 
      styleClass="main-container">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="action-bar">
        <Label styleClass="page-title" text="📒 My Journal Vault" />
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕ New Notebook" onAction="#handleNewNotebook" styleClass="primary-button" />
        <Button text="🔄 Refresh" onAction="#loadData" styleClass="secondary-button" />
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="cards-scroll">
        <FlowPane fx:id="notebooksContainer" hgap="25" vgap="25" styleClass="cards-container">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        </FlowPane>
    </ScrollPane>
</VBox>
